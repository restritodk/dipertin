# Cursor IDE
.cursor/

# Scripts locais
criar_repo_e_push.ps1

# Flutter / Dart (monorepo)
**/.dart_tool/
**/.flutter-plugins-dependencies
**/build/
**/coverage/
**/doc/api/
.pub-cache/
.pub/

# Android
**/android/.gradle/
**/android/local.properties
**/android/**/captures/

# iOS
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/ephemeral/

# Cloud Functions
**/node_modules/

# Variaveis de ambiente (nunca commitar)
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# IDE
.idea/
*.iml
*.ipr
*.iws

# Logs e temp
*.log
**/firebase-debug.log
# Cache do Firebase CLI (ex.: `firebase deploy` no site)
**/.firebase/
.DS_Store

# Chaves de serviço Firebase (nunca commitar)
**/serviceAccount*.json
**/*-firebase-adminsdk-*.json

# OAuth / segredos do Google (nunca no frontend; apenas client_id pode ir no código)
**/client_secret*.json
**/web/client_secret*.json

# Keystore de release Android (NUNCA commitar — perder = perder o app na Play Store)
**/android/key.properties
**/android/*.jks
**/android/**/*.keystore
# Exceção: o google-services.json É commitado (contém apenas IDs públicos)
!**/android/app/google-services.json
