<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F0F7"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/chamada_titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Nova corrida"
        android:textColor="#111111"
        android:textSize="23sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/chamada_valor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="R$ 0,00"
        android:textColor="#FF8F00"
        android:textSize="38sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/chamada_valor_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="ganho líquido"
        android:textColor="#555555"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="#FFF8EE"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/chamada_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aceite em 15s"
            android:textColor="#FF8F00"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/chamada_timer_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:indeterminate="false"
            android:max="15"
            android:progress="15"
            android:progressTint="#FF8F00" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/chamada_coleta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Coleta: —"
            android:textColor="#1D1D1D"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/chamada_entrega"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Entrega: —"
            android:textColor="#1D1D1D"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/chamada_metas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Você→Loja: —   •   Loja→Cliente: —"
            android:textColor="#505050"
            android:textSize="13sp" />
    </LinearLayout>

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/chamada_btn_recusar"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="#FFFFFF"
            android:text="Recusar"
            android:textAllCaps="false"
            android:textColor="#5E35B1"
            android:textSize="16sp" />

        <Button
            android:id="@+id/chamada_btn_aceitar"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:layout_weight="2"
            android:backgroundTint="#6A1B9A"
            android:text="Aceitar corrida"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />
    </LinearLayout>
</LinearLayout>
