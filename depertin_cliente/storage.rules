rules_version = '2';

// DiPertin — Firebase Storage
// Caminhos usados no app: produtos/..., banners_vitrine/..., fotos_perfil/...

service firebase.storage {
  match /b/{bucket}/o {

    // Em delete, request.resource é null — não use size/contentType no mesmo allow write.
    match /produtos/{allPaths=**} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    match /banners_vitrine/{allPaths=**} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    match /fotos_perfil/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && fileName == request.auth.uid + '.jpg'
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /documentos_lojistas/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 20 * 1024 * 1024;
    }

    match /documentos_entregadores/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 20 * 1024 * 1024;
    }

    match /utilidades/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024;
    }

    match /candidaturas/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
