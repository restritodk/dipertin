rules_version = '2';

// DiPertin — Firebase Storage
// Caminhos usados no app: produtos/..., banners_vitrine/..., fotos_perfil/...,
//                         documentos_lojistas/{uid}/..., documentos_entregadores/{uid}/...,
//                         utilidades/..., candidaturas/..., suporte_anexos/{ticketId}/...

service firebase.storage {
  match /b/{bucket}/o {

    // Helpers -------------------------------------------------------------
    // firestore.get() em Storage Rules tem custo (1 leitura por request),
    // mas é essencial para autorizar staff/dono cross-serviço.
    // IMPORTANTE: só é válido chamar dentro de um bloco que JÁ garantiu
    // request.auth != null — senão o .get() falha com permission denied.
    function userRole() {
      return firestore.get(
        /databases/(default)/documents/users/$(request.auth.uid)
      ).data;
    }

    // Normaliza string p/ comparar sem depender de capitalização/whitespace
    // (mesmo padrão usado no painel web em `admin_perfil.dart`).
    function normalizeRole(v) {
      return v is string ? v.lower().trim() : '';
    }

    function hasStaffRole(data) {
      return normalizeRole(data.get('role', '')) in ['master', 'master_city', 'superadmin', 'super_admin']
        || normalizeRole(data.get('tipo', '')) in ['master', 'master_city', 'superadmin', 'super_admin']
        || normalizeRole(data.get('tipoUsuario', '')) in ['master', 'master_city', 'superadmin', 'super_admin'];
    }

    function isStaff() {
      return request.auth != null && hasStaffRole(userRole());
    }

    function isImageUnder(sizeBytes) {
      return request.resource.size < sizeBytes
        && request.resource.contentType.matches('image/.*');
    }

    // Produtos ------------------------------------------------------------
    // Dois padrões de path em uso:
    //   (A) produtos/{uidLoja}/{arquivo}          — telas "novo produto"
    //   (B) produtos/{uidLoja}_{timestamp}.jpg    — telas legadas
    // A leitura é pública (catálogo do marketplace).
    // Create/update/delete exigem que o uid do auth case com o path/filename.

    match /produtos/{uidLoja}/{allPaths=**} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == uidLoja
        && isImageUnder(15 * 1024 * 1024);
      allow delete: if request.auth != null
        && (request.auth.uid == uidLoja || isStaff());
    }

    match /produtos/{fileName} {
      // Padrão legado: o filename precisa começar com o uid do lojista seguido de `_`.
      // Ex.: "abc123_1713471234567.jpg" aceito para uid "abc123".
      allow read: if true;
      allow create, update: if request.auth != null
        && fileName.matches(request.auth.uid + '_.*')
        && isImageUnder(15 * 1024 * 1024);
      allow delete: if request.auth != null
        && (fileName.matches(request.auth.uid + '_.*') || isStaff());
    }

    // Banners da vitrine --------------------------------------------------
    // Gerenciado APENAS pelo painel web (menu "Banners da vitrine"),
    // que só aparece pra staff (master/master_city/superadmin) via
    // `perfilPodeGestaoLojasEntregadoresBanners` em admin_perfil.dart.
    // No Storage, permitimos qualquer autenticado a escrever/apagar, porque
    // a checagem cross-service via firestore.get() não é confiável aqui
    // (o fallback real fica no Firestore rules: o doc `banners/{id}` tem
    // write restrito a staff, então mesmo que alguém delete o arquivo por
    // fora, não consegue manipular o registro). Pra compensar o risco de
    // vandalismo, no futuro podemos migrar pra Cloud Function (admin SDK).
    match /banners_vitrine/{allPaths=**} {
      allow read: if true;
      allow create, update: if request.auth != null
        && isImageUnder(15 * 1024 * 1024);
      allow delete: if request.auth != null;
    }

    // Foto de perfil ------------------------------------------------------
    match /fotos_perfil/{fileName} {
      allow read: if true;
      allow create, update: if request.auth != null
        && fileName == request.auth.uid + '.jpg'
        && isImageUnder(5 * 1024 * 1024);
      allow delete: if request.auth != null
        && fileName == request.auth.uid + '.jpg';
    }

    // Documentos pessoais do lojista (CNH/RG/Comprovante) -----------------
    // Só o próprio lojista OU staff lê/baixa. Uploads só pelo dono do uid.
    // Limite 20 MB p/ acomodar PDFs escaneados. Sem restrição de tipo
    // (o app também envia PDFs).
    match /documentos_lojistas/{userId}/{allPaths=**} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isStaff());
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 20 * 1024 * 1024;
      allow delete: if request.auth != null
        && (request.auth.uid == userId || isStaff());
    }

    // Documentos pessoais do entregador (CNH/CRLV/Foto veículo) -----------
    // Staff (painel web) pode enviar em nome do entregador ao corrigir cadastro.
    match /documentos_entregadores/{userId}/{allPaths=**} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isStaff());
      allow create, update: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && (
          request.auth.uid == userId
          || isStaff()
        );
      allow delete: if request.auth != null
        && (request.auth.uid == userId || isStaff());
    }

    // Utilidades (vagas, achados, eventos) --------------------------------
    // Leitura pública (catálogo); escrita por qualquer autenticado.
    // Delete restrito a staff pra evitar vandalismo entre usuários.
    match /utilidades/{allPaths=**} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024;
      allow delete: if isStaff();
    }

    // Candidaturas a vagas ------------------------------------------------
    // Leitura só para autenticados (o staff lê pra avaliar candidaturas).
    // Escrita por autenticados (o candidato envia seus anexos).
    // Delete só staff.
    match /candidaturas/{allPaths=**} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if isStaff();
    }

    // Anexos da Central de Ajuda ------------------------------------------
    // Cliente e atendente trocam arquivos. Controle fino de quem envia o
    // quê é feito no Firestore (/support_tickets/.../mensagens).
    // Delete aqui fica restrito a staff (cliente comum não apaga).
    match /suporte_anexos/{ticketId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
      allow delete: if isStaff();
    }
  }
}
