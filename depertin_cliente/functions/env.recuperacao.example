# Copie este ficheiro para .env na pasta functions/ e preencha.
# O ficheiro .env NÃO deve ser commitado (já está no .gitignore).

# ─── Host e porta compartilhados (mesmo provedor Titan/HostGator) ───
SMTP_HOST=smtp.titan.email
SMTP_PORT=465

# ─── Conta PADRÃO (sistema): boas-vindas, recuperação, contato, saques ───
SMTP_USER=naoresponder@seudominio.com.br
SMTP_PASS=sua_senha_smtp_padrao
SMTP_FROM=DiPertin <naoresponder@seudominio.com.br>

# ─── Conta CANDIDATURA: exclusiva para vagas de emprego ───
SMTP_CANDIDATURA_USER=candidatura@seudominio.com.br
SMTP_CANDIDATURA_PASS=sua_senha_smtp_candidatura
SMTP_CANDIDATURA_FROM=DiPertin Vagas <candidatura@seudominio.com.br>

# ─── OTP — Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" ───
OTP_RECUPERACAO_PEPPER=hexadecimal_longo_aleatorio

# ─── Destino do formulário de contato do site ───
SMTP_SITE_DEST=site@seudominio.com.br
