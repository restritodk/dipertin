{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "seed:toledo": "node scripts/seed_produto_toledo_pr.js",
    "seed:superadmin": "node scripts/seed_superadmin_painel.js",
    "seed:master": "node scripts/seed_master_painel.js",
    "reset:usuarios-superadmin": "node scripts/reset_usuarios_somente_superadmin.js",
    "wipe:livro-caixa": "node scripts/wipe_livro_caixa_firestore.js",
    "wipe:marketplace-usuarios": "node scripts/wipe_marketplace_usuarios_firestore.js",
    "wipe:marketplace-lancamentos": "node scripts/wipe_marketplace_lancamentos_only_firestore.js",
    "creditar:lojista": "node scripts/creditar_saldo_lojista.js",
    "seed:atualizacao-app": "node scripts/seed_atualizacao_app.js",
    "test": "node --test test/*.test.js",
    "test:emulator": "firebase emulators:exec \"node test/create-fixtures.js && node --test test/*.test.js\" --project demo-depertin-teste",
    "test:unit": "node --test test/*.test.js",
    "test:integrated": "cd .. && firebase emulators:exec \"cd functions && node test/create-fixtures.js && node --test-concurrency=1 test/*.integration.test.js\" --project demo-depertin-teste"
  },
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "dependencies": {
    "@google-cloud/firestore": "^7.11.0",
    "dotenv": "^16.4.7",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0",
    "node-forge": "^1.4.0",
    "nodemailer": "^6.9.16",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase-functions-test": "^3.4.1"
  },
  "private": true
}
