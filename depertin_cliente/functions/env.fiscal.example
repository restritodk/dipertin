# ═══════════════════════════════════════════════════════════════════════════
# Variáveis de Ambiente — Módulo Fiscal NF-e
# ═══════════════════════════════════════════════════════════════════════════
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env (NUNCA commitar o .env real)
# 2. Preencha os valores conforme o ambiente (produção / homologação)
# 3. Use `gcloud secrets` ou Firebase Secret Manager em produção
# 4. As chaves mestras são usadas para criptografar dados sensíveis no Firestore
#
# AVISO: ALTERAR A CHAVE MESTRA INVALIDARÁ TODOS OS DADOS CRIPTOGRAFADOS
# (tokens, API keys, certificados, senhas já salvos no Firestore).
# ═══════════════════════════════════════════════════════════════════════════

# ─── Chave Mestra Fiscal ──────────────────────────────────────────────────
# AES-256-GCM: chave de 64 caracteres hex (32 bytes) usada para criptografar
# tokens, API keys, certificados A1 e senhas no Firestore.
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FISCAL_MASTER_KEY=

# ─── Webhook Fiscal ───────────────────────────────────────────────────────
# Secret usado para validar webhooks recebidos de provedores fiscais.
# Provedores que usam: Focus NFe (HMAC SHA256), PlugNotas, Enotas.
# Gerar com: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
FISCAL_WEBHOOK_SECRET=

# ─── URLs dos Provedores (opcional — sobrescreve defaults) ────────────────
# Se vazio, usa as URLs padrão de cada provedor
# FOCUS_NFE_BASE_URL=https://api.focusnfe.com.br
# ENOTAS_BASE_URL=https://api.enotas.com.br
# PLUG_NOTAS_BASE_URL=https://api.plugnotas.com.br
# NUVEM_FISCAL_BASE_URL=https://api.nuvemfiscal.com.br
# WEBMANIA_BASE_URL=https://webmaniabr.com/api/1/nfe/

# ─── Limite Mensal Padrão ─────────────────────────────────────────────────
# Limite de emissão mensal padrão para novos lojistas (se não configurado)
FISCAL_LIMITE_PADRAO_MENSAL=200

# ─── Webhook Callback URL (opcional) ──────────────────────────────────────
# URL base do webhook (geralmente auto-descoberta pelo Firebase)
# FISCAL_WEBHOOK_BASE_URL=https://us-central1-depertin-f940f.cloudfunctions.net

# ─── Certificado A1 ───────────────────────────────────────────────────────
# Tempo em dias antes do vencimento para emitir alerta
FISCAL_CERT_ALERTA_DIAS=30
