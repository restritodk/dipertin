# ── SMTP —────────────
# Host e porta do provedor SMTP (ex: Titan/HostGator/AWS SES)
SMTP_HOST=smtp.example.com
SMTP_PORT=465

# Conta padrão do sistema (boas-vindas, recuperação de senha, etc.)
SMTP_USER=naoresponder@exemplo.com.br
SMTP_PASS=SUA_SENHA_AQUI
SMTP_FROM="Exemplo <naoresponder@exemplo.com.br>"

# Conta de candidatura para vagas de emprego
SMTP_CANDIDATURA_USER=candidatura@exemplo.com.br
SMTP_CANDIDATURA_PASS=SUA_SENHA_AQUI
SMTP_CANDIDATURA_FROM="Exemplo Vagas <candidatura@exemplo.com.br>"

# Pepper para hash OTP de recuperação de senha (gerar com crypto.randomBytes(32).toString('hex'))
OTP_RECUPERACAO_PEPPER=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789

# Destino do formulário de contato do site
SMTP_SITE_DEST=site@exemplo.com.br

# Destino para solicitações de exclusão de conta (LGPD)
SMTP_DELETE_ACCOUNT_DEST=lgpd@exemplo.com.br

# Chave de API Comtele (SMS)
COMTELE_AUTH_KEY=00000000-0000-0000-0000-000000000000

# ─── Módulo Fiscal NF-e ──────────────────────────────────────────────────
# Chave mestra OBRIGATÓRIA para criptografia AES-256-GCM dos tokens fiscais.
# Deve ter 64 caracteres hex (SHA-256 do valor original → 256 bits).
# Configurar via Firebase Secret Manager:
#   firebase functions:secrets:set FISCAL_MASTER_KEY
# NÃO existe fallback hardcoded no código. NÃO versionar valor real.
FISCAL_MASTER_KEY=

# Secret do webhook fiscal para validação HMAC
FISCAL_WEBHOOK_SECRET=

# Secret MP (Mercado Pago) para validação HMAC do webhook
# Usado exclusivamente do lado Functions, nunca no frontend
MP_WEBHOOK_SECRET=

# ATENÇÃO: SE NÃO EXISTIR, DESCOMENTAR E CONFIGURAR:
# Permite webhooks sem assinatura (APENAS para integração inicial / debug)
# MP_WEBHOOK_ALLOW_UNSIGNED=true
